---
import { url } from '../lib/url';
const links = [
  { href: url('#work'), label: 'Work' },
  { href: url('experience'), label: 'Experience' },
  { href: url('about'), label: 'About' },
  { href: url('contact'), label: 'Contact' },
];
---
<header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]/80 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href={url()} class="text-sm font-semibold tracking-tight">
      Mike Gebremeskel
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-6 text-sm text-[var(--color-text-secondary)]">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="hover:text-[var(--color-text-primary)] transition-colors"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
