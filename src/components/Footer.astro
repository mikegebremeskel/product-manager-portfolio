---
import { url } from '../lib/url';
const year = new Date().getFullYear();

const pages = [
  { href: url(), label: 'Home' },
  { href: url('writing'), label: 'Writing' },
  { href: url('experience'), label: 'Experience' },
  { href: url('about'), label: 'About' },
  { href: url('contact'), label: 'Contact' },
];

// Social glyphs reuse the inline SVG paths from SocialLinks.astro.
const socials = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/mikegebremeskel/',
    path: 'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/mikegebremeskel',
    path: 'M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z',
  },
  {
    label: 'Substack',
    href: 'https://substack.com/@mikegebremeskel',
    path: 'M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z',
  },
];
---
<footer class="bg-[var(--color-text-primary)] text-[var(--color-bg-primary)]">
  <div class="mx-auto max-w-7xl px-6 pt-16 pb-12">
    <!-- Top region -->
    <div class="flex flex-wrap justify-between gap-12">
      <!-- Brand + CTA -->
      <div class="max-w-[34ch]">
        <p class="text-2xl font-semibold tracking-tight">Mike Gebremeskel<span class="text-[var(--color-accent-strong)]">.</span></p>
        <p class="mt-3 leading-relaxed text-[rgba(251,251,253,0.6)]">
          I ask "why" a lot, hold a high bar, and believe people do their best work when they feel trusted.
        </p>
        <a
          href={url('contact')}
          class="mt-6 inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-5 py-3 text-sm font-medium text-[var(--color-accent-contrast)] transition-colors hover:bg-[var(--color-accent-hover)]"
        >
          Get in touch
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>

      <!-- Link columns -->
      <nav aria-label="Footer" class="flex flex-wrap gap-10 sm:gap-16">
        <div>
          <p class="f-label">Pages</p>
          <ul class="mt-4 flex flex-col gap-3">
            {pages.map((p) => (
              <li>
                <a href={p.href} class="fl inline-flex min-h-[44px] items-center text-sm text-[rgba(251,251,253,0.8)]">
                  <span class="foot-link">{p.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="f-label">Elsewhere</p>
          <ul class="mt-4 flex flex-col gap-3">
            {socials.map((s) => (
              <li>
                <a href={s.href} rel="noopener" aria-label={`Mike Gebremeskel on ${s.label}`} class="fl inline-flex min-h-[44px] items-center gap-2 text-sm text-[rgba(251,251,253,0.8)]">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path} /></svg>
                  <span class="foot-link">{s.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-wrap justify-between gap-2 border-t border-[rgba(251,251,253,0.12)] pt-6 font-mono text-xs text-[rgba(251,251,253,0.45)]">
      <span>© {year} Mike Gebremeskel</span>
      <span>Standards high, energy higher.</span>
    </div>
  </div>
</footer>

<style>
  /* Mono label, matched to .eyebrow but tuned for the dark band. */
  .f-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(251, 251, 253, 0.5);
  }
  /* Underline-grow on the text span; the anchor carries the 44px hit area. */
  .foot-link {
    background-image: linear-gradient(currentColor, currentColor);
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 1.5px;
    transition: background-size 200ms var(--ease-standard);
  }
  .fl:hover .foot-link,
  .fl:focus-visible .foot-link {
    background-size: 100% 1.5px;
  }
  /* Keyboard focus must read on #1D1D1F: a light ring scoped to the footer. */
  footer :focus-visible {
    outline: 2px solid rgba(251, 251, 253, 0.9);
    outline-offset: 2px;
    border-radius: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .foot-link { transition: none; }
  }
</style>
