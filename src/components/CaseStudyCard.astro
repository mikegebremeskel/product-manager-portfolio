---
interface Props {
  href: string;
  title: string;
  summary: string;
  competencies: string[];
}
const { href, title, summary, competencies } = Astro.props;
---
{/*
  Stretched-link pattern: only the title is the link, so a screen reader
  announces just the case study title as the link name. The link's ::after
  overlay makes the whole card clickable, and focus-within rings the card.
*/}
<article class="reveal group relative flex flex-col rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-6 transition-colors hover:bg-[var(--color-bg-elevated)] focus-within:outline-none focus-within:ring-2 focus-within:ring-[var(--color-accent-green)]">
  <h3 class="text-xl font-medium text-[var(--color-text-primary)] transition-colors group-hover:text-[var(--color-accent-green)]">
    <a href={href} class="after:absolute after:inset-0 after:content-[''] focus:outline-none">
      {title}
    </a>
  </h3>
  <p class="mt-2 text-[var(--color-text-secondary)] leading-relaxed text-pretty">
    {summary}
  </p>
  <ul class="mt-4 flex flex-wrap gap-2">
    {competencies.map((c) => (
      <li class="rounded-sm border border-[var(--color-border)] px-2 py-0.5 text-xs text-[var(--color-text-secondary)]">
        {c}
      </li>
    ))}
  </ul>
</article>
