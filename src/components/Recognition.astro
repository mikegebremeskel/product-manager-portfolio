---
import { url } from '../lib/url';

// Award collage modeled on the Talisman site treatment: the Awwwards certificate
// as the base (its dark mat blends into the dark page), with the Product Hunt
// badge and the three CSSDA medallions overlapping. The overlaps mean no single
// badge sits alone on the dark background, so contrast takes care of itself.
---
<section class="mx-auto max-w-7xl px-6 pb-24">
  <h2 class="text-center text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-balance">
    <span class="text-[var(--color-text-secondary)]">Loved by users,</span><br />
    awarded by peers
  </h2>
  <p class="mx-auto mt-5 max-w-2xl lg:max-w-3xl text-center text-[var(--color-text-secondary)] text-lg leading-relaxed text-pretty">
    I led Talisman's February 2024 launch as product manager and co-founder, working closely with our design partners. It reached #1 SaaS Product of the Week on Product Hunt, was named Fintech Startup of the Year by This Week in Fintech, and earned Awwwards Honors and CSSDA awards for UI, UX, and Innovation.
  </p>

  <div class="relative mx-auto mt-10 w-full max-w-2xl lg:max-w-3xl aspect-[6/5]">
    <!-- Awwwards certificate (base) -->
    <img
      src={url('assets/awwwards-honors.png')}
      alt="Awwwards Honors certificate awarded to Talisman, March 2024"
      class="absolute left-[14%] top-0 z-10 w-[44%] -rotate-3 drop-shadow-2xl"
      loading="lazy"
    />
    <!-- Product Hunt badge -->
    <a
      href="https://www.producthunt.com/products/talisman-2"
      rel="noopener"
      class="absolute left-[2%] top-[44%] z-30 block w-[62%] -rotate-2 drop-shadow-xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent-green)] rounded-2xl"
      aria-label="Product Hunt: #1 SaaS Product of the Week"
    >
      <img src={url('assets/producthunt-1-saas.svg')} alt="Product Hunt badge: #1 SaaS Product of the Week" class="w-full" />
    </a>
    <!-- CSSDA medallions, clustered bottom-right and overlapping -->
    <img
      src={url('assets/cssda-best-ui.png')}
      alt="CSSDA Best UI Design award"
      class="absolute right-[24%] top-[28%] z-20 w-[27%] -rotate-6 drop-shadow-xl"
      loading="lazy"
    />
    <img
      src={url('assets/cssda-best-ux.png')}
      alt="CSSDA Best UX Design award"
      class="absolute right-[6%] top-[37%] z-30 w-[27%] rotate-6"
      style="filter: drop-shadow(0 0 1px rgba(255,255,255,0.6)) drop-shadow(0 8px 16px rgba(0,0,0,0.5));"
      loading="lazy"
    />
    <img
      src={url('assets/cssda-best-innovation.png')}
      alt="CSSDA Best Innovation award"
      class="absolute right-[16%] bottom-[2%] z-40 w-[31%] rotate-3 drop-shadow-2xl"
      loading="lazy"
    />
  </div>
</section>
