---
import { url } from '../lib/url';

// Award collage modeled on the Talisman site treatment: the Awwwards certificate
// as the base, with the Product Hunt badge and the three CSSDA medallions
// overlapping. On the light canvas each piece gets a soft drop-shadow
// (--shadow-collage / --shadow-overlay) so it reads as a floating object and
// no badge blends into the warm-white background.
---
<section class="mx-auto max-w-7xl px-6 pb-24">
  <h2 class="reveal text-center text-3xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-balance">
    <span class="text-[var(--color-text-secondary)]">Loved by users,</span><br />
    awarded by peers
  </h2>
  <p class="reveal mx-auto mt-5 max-w-2xl lg:max-w-3xl text-center text-[var(--color-text-secondary)] text-lg leading-relaxed text-pretty">
    I led Talisman's February 2024 launch as product manager and co-founder, working closely with our design partners. It reached #1 SaaS Product of the Week on Product Hunt, was named Fintech Startup of the Year by This Week in Fintech, and earned Awwwards Honors and CSSDA awards for UI, UX, and Innovation.
  </p>

  {/*
    Below sm: a centered flex-wrap of legibly-sized badges (no overlap, no rotation).
    At sm+: the original absolute, overlapping, rotated collage inside a 6:5 box.
  */}
  <div class="reveal mx-auto mt-10 flex w-full max-w-2xl flex-wrap items-center justify-center gap-6 sm:relative sm:mt-12 sm:block sm:gap-0 sm:aspect-[6/5] lg:max-w-3xl">
    <!-- Awwwards certificate (base) -->
    <img
      src={url('assets/awwwards-honors.png')}
      alt="Awwwards Honors certificate awarded to Talisman, March 2024"
      class="w-32 sm:absolute sm:left-[14%] sm:top-0 sm:z-10 sm:w-[44%] sm:-rotate-3"
      style="filter: drop-shadow(var(--shadow-collage));"
      loading="lazy"
    />
    <!-- Product Hunt badge -->
    <a
      href="https://www.producthunt.com/products/talisman-2"
      rel="noopener"
      class="block w-44 rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent-strong)] sm:absolute sm:left-[2%] sm:top-[44%] sm:z-30 sm:w-[62%] sm:-rotate-2"
      style="filter: drop-shadow(var(--shadow-overlay));"
      aria-label="Product Hunt: #1 SaaS Product of the Week"
    >
      <img src={url('assets/producthunt-1-saas.svg')} alt="Product Hunt badge: #1 SaaS Product of the Week" class="w-full" />
    </a>
    <!-- CSSDA medallions, clustered bottom-right and overlapping at sm+ -->
    <img
      src={url('assets/cssda-best-ui.png')}
      alt="CSSDA Best UI Design award"
      class="w-24 sm:absolute sm:right-[24%] sm:top-[28%] sm:z-20 sm:w-[27%] sm:-rotate-6"
      style="filter: drop-shadow(var(--shadow-overlay));"
      loading="lazy"
    />
    <img
      src={url('assets/cssda-best-ux.png')}
      alt="CSSDA Best UX Design award"
      class="w-24 sm:absolute sm:right-[6%] sm:top-[37%] sm:z-30 sm:w-[27%] sm:rotate-6"
      style="filter: drop-shadow(var(--shadow-overlay));"
      loading="lazy"
    />
    <img
      src={url('assets/cssda-best-innovation.png')}
      alt="CSSDA Best Innovation award"
      class="w-24 sm:absolute sm:right-[16%] sm:bottom-[2%] sm:z-40 sm:w-[31%] sm:rotate-3"
      style="filter: drop-shadow(var(--shadow-collage));"
      loading="lazy"
    />
  </div>
</section>
