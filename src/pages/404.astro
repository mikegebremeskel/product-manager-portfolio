---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../lib/url';
---
<BaseLayout title="Not found" description="That page doesn't exist.">
  <section class="mx-auto max-w-xl px-6 py-32 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-4 text-4xl font-semibold tracking-tight">That page doesn't exist.</h1>
    <p class="mt-4 text-[var(--color-text-secondary)]">
      Try the <a href={url()} class="text-[var(--color-accent-strong)] underline underline-offset-4">home page</a>.
    </p>
  </section>
</BaseLayout>
