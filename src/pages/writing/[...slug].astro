---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const essays = await getCollection('writing');
  return essays.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = await getCollection('writing');
const related = (entry.data.related ?? [])
  .map((id) => all.find((e) => e.id === id))
  .filter(Boolean);

const dateLabel = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC',
});

const canonical = new URL(`${import.meta.env.BASE_URL}writing/${entry.id}`, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.summary,
  author: { '@type': 'Person', name: 'Mike Gebremeskel', url: Astro.site?.toString() },
  datePublished: entry.data.date.toISOString().slice(0, 10),
  url: canonical,
};
const headshot = url('assets/headshot.jpeg');
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-24">
    <header>
      <p class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)]">Writing</p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-balance">{entry.data.title}</h1>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)] leading-relaxed text-pretty">{entry.data.summary}</p>
    </header>

    <div class="prose-portfolio mt-10">
      <Content />
    </div>

    <p class="mt-12 text-sm text-[var(--color-text-secondary)]">{dateLabel}</p>

    <!-- Author / CTA -->
    <aside class="mt-10 flex flex-col gap-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-6 sm:flex-row sm:items-center">
      <img src={headshot} alt="Mike Gebremeskel" width="64" height="64" class="h-16 w-16 shrink-0 rounded-full border border-[var(--color-border)] object-cover" />
      <div class="flex-1">
        <p class="font-medium text-[var(--color-text-primary)]">Mike Gebremeskel</p>
        <div class="mt-3 flex flex-wrap items-center gap-5 text-sm">
          <a href={url('contact')} class="rounded-md bg-[var(--color-accent-green)] px-4 py-2 font-medium text-[var(--color-bg-primary)] hover:opacity-90 transition-opacity">Get in touch</a>
          <a href={url('#work')} class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">See my work →</a>
          <SocialLinks />
        </div>
      </div>
    </aside>

    {related.length > 0 && (
      <nav class="mt-12 border-t border-[var(--color-border)] pt-6" aria-label="Related writing">
        <p class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)] mb-4">More writing</p>
        <ul class="space-y-3">
          {related.map((r) => (
            <li>
              <a href={url(`writing/${r.id}`)} class="text-[var(--color-text-primary)] hover:text-[var(--color-accent-green)] transition-colors">
                {r.data.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</BaseLayout>
