---
import BaseLayout from '../layouts/BaseLayout.astro';

// Formspree holds Mike's email server-side and forwards submissions, so the
// address never appears in the page source (PRD requirement). The endpoint ID
// is public by design; override via PUBLIC_FORMSPREE_ENDPOINT if it ever changes.
const FORMSPREE_ENDPOINT = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT || 'https://formspree.io/f/xeewbbqj';

const fieldClass =
  "w-full rounded-md border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-3.5 py-2.5 text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] transition-colors focus:outline-none focus:border-[var(--color-accent-green)] focus:ring-2 focus:ring-[var(--color-accent-green)]";
const labelClass = "block text-sm font-medium text-[var(--color-text-secondary)] mb-2";
---
<BaseLayout title="Contact" description="Get in touch with Mike Gebremeskel.">
  <section class="mx-auto max-w-xl px-6 pt-16 pb-24">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">Contact</h1>
    <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed text-pretty">
      Send a note and I'll get back to you. I keep my email off the site on purpose.
    </p>

    <form
      id="contact-form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
      class="mt-8 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] p-6 sm:p-8 space-y-5"
    >
      <div>
        <label for="name" class={labelClass}>Name</label>
        <input id="name" name="name" type="text" required autocomplete="name" placeholder="Jane Doe" class={fieldClass} />
      </div>
      <div>
        <label for="email" class={labelClass}>Email</label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="jane@company.com" class={fieldClass} />
      </div>
      <div>
        <label for="company" class={labelClass}>Company <span class="font-normal text-[var(--color-text-muted)]">(optional)</span></label>
        <input id="company" name="company" type="text" autocomplete="organization" placeholder="Where you're reaching out from" class={fieldClass} />
      </div>
      <div>
        <label for="message" class={labelClass}>Message</label>
        <textarea id="message" name="message" rows="6" required placeholder="What's on your mind?" class={fieldClass}></textarea>
      </div>

      {/* Honeypot: bots fill it, humans don't see it. */}
      <div class="hidden" aria-hidden="true">
        <label>Leave this field empty<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
      </div>

      <button
        type="submit"
        class="w-full sm:w-auto rounded-md bg-[var(--color-accent-green)] px-6 py-2.5 text-sm font-medium text-[var(--color-bg-primary)] hover:opacity-90 transition-opacity focus:outline-none focus:ring-2 focus:ring-[var(--color-accent-green)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg-card)]"
      >
        Send
      </button>

      <p id="form-success" class="hidden text-sm text-[var(--color-accent-green)]" role="status">
        Thanks, message sent. I'll reply soon.
      </p>
      <p id="form-error" class="hidden text-sm text-[var(--color-status-red)]" role="alert">
        Something went wrong. Please try again, or reach out on LinkedIn.
      </p>
    </form>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const okMsg = document.getElementById('form-success');
    const errMsg = document.getElementById('form-error');
    if (form && okMsg && errMsg) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        okMsg.classList.add('hidden');
        errMsg.classList.add('hidden');
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (res.ok) {
            form.reset();
            okMsg.classList.remove('hidden');
          } else {
            errMsg.classList.remove('hidden');
          }
        } catch {
          errMsg.classList.remove('hidden');
        }
      });
    }
  </script>
</BaseLayout>
