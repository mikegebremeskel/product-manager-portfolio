---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((e) => e.id === entry.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-24">
    <header>
      <p class="text-sm uppercase tracking-widest text-[var(--color-text-secondary)]">
        {entry.data.company ?? 'Case study'}
      </p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-balance">
        {entry.data.title}
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)] leading-relaxed text-pretty">
        {entry.data.summary}
      </p>
      <ul class="mt-6 flex flex-wrap gap-2">
        {entry.data.competencies.map((c) => (
          <li class="rounded-sm border border-[var(--color-border)] px-2 py-0.5 text-xs text-[var(--color-text-secondary)]">
            {c}
          </li>
        ))}
      </ul>
    </header>

    <div class="article-body prose-portfolio mt-12">
      <Content />
    </div>

    <nav class="mt-16 flex items-center justify-between border-t border-[var(--color-border)] pt-6 text-sm">
      {prev ? (
        <a href={`${base}work/${prev.id}`} class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">
          ← {prev.data.title}
        </a>
      ) : <span />}
      {next ? (
        <a href={`${base}work/${next.id}`} class="text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors text-right">
          {next.data.title} →
        </a>
      ) : <span />}
    </nav>
  </article>
</BaseLayout>

<style is:global>
  .prose-portfolio {
    color: var(--color-text-primary);
    line-height: 1.75;
    max-width: 65ch;
  }
  .prose-portfolio > * + * { margin-top: 1.25em; }
  .prose-portfolio h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 3rem;
    text-wrap: balance;
  }
  .prose-portfolio h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 2rem;
  }
  .prose-portfolio p { color: var(--color-text-primary); }
  .prose-portfolio strong { color: var(--color-text-primary); font-weight: 600; }
  .prose-portfolio a {
    color: var(--color-accent-green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-portfolio ul { padding-left: 1.25rem; list-style: disc; }
  .prose-portfolio li + li { margin-top: 0.5rem; }
  .prose-portfolio blockquote {
    border-left: 3px solid var(--color-accent-gold);
    padding: 1rem 1.25rem;
    background: var(--color-bg-surface);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-style: normal;
  }
  .prose-portfolio blockquote p { margin: 0; }
  .prose-portfolio blockquote + * { margin-top: 2rem; }
  .prose-portfolio img {
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    margin-top: 2rem;
    width: 100%;
    height: auto;
  }
  .prose-portfolio img + em,
  .prose-portfolio p > em:only-child {
    display: block;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 0.5rem;
    font-style: italic;
  }
  .prose-portfolio hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }
  .prose-portfolio code {
    background: var(--color-bg-surface);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
  }
</style>
