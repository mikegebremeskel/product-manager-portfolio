---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const work = await getCollection('work');
  return work.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const all = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((e) => e.id === entry.id);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-24">
    <header>
      <p class="eyebrow">
        {entry.data.company ?? 'Case study'}
      </p>
      <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-balance">
        {entry.data.title}
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-secondary)] leading-relaxed text-pretty">
        {entry.data.summary}
      </p>
      <ul class="mt-6 flex flex-wrap gap-2">
        {entry.data.competencies.map((c) => (
          <li class="rounded-sm border border-[var(--color-border)] px-2 py-0.5 text-xs text-[var(--color-text-secondary)]">
            {c}
          </li>
        ))}
      </ul>

      <dl class="mt-8 grid gap-x-8 gap-y-4 border-t border-[var(--color-border)] pt-6 sm:grid-cols-[8rem_1fr]">
        <dt class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] sm:pt-0.5">Role</dt>
        <dd class="leading-relaxed -mt-3 sm:mt-0">{entry.data.role}</dd>

        <dt class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] sm:pt-0.5">Timeline</dt>
        <dd class="leading-relaxed -mt-3 sm:mt-0">{entry.data.timeline}</dd>

        {entry.data.workedWith && (
          <>
            <dt class="text-xs uppercase tracking-widest text-[var(--color-text-secondary)] sm:pt-0.5">Worked with</dt>
            <dd class="leading-relaxed -mt-3 sm:mt-0">{entry.data.workedWith}</dd>
          </>
        )}
      </dl>
    </header>

    <div class="article-body prose-portfolio mt-12">
      <Content />
    </div>

    <nav class="mt-16 flex flex-wrap items-start justify-between gap-4 border-t border-[var(--color-border)] pt-6 text-sm">
      {prev ? (
        <a href={url(`work/${prev.id}`)} class="min-w-0 text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">
          ← {prev.data.title}
        </a>
      ) : <span />}
      {next ? (
        <a href={url(`work/${next.id}`)} class="min-w-0 text-right text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">
          {next.data.title} →
        </a>
      ) : <span />}
    </nav>
  </article>
</BaseLayout>
