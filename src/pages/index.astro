---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import Recognition from '../components/Recognition.astro';
import Testimonials from '../components/Testimonials.astro';
import { url } from '../lib/url';

const heroPhoto = url('assets/hero.jpeg');

const work = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Mike Gebremeskel" description="Product manager. Co-founder of Talisman, a venture-backed B2B SaaS startup, and the PM behind its award-winning launch.">
  <section class="relative mx-auto max-w-7xl px-6 pt-24 pb-20 lg:pt-32 lg:pb-28">
    <div class="glow-field"></div>
    <div class="relative z-10 grid items-center gap-10 lg:grid-cols-[1.6fr_1fr] lg:gap-16">
      <div>
        <p class="eyebrow">Product manager</p>
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-balance sm:text-5xl md:text-6xl lg:text-7xl lg:[letter-spacing:var(--tracking-tighter)]">
          I empathize with users to build intuitive products.
        </h1>
        <p class="mt-8 max-w-2xl text-lg lg:text-xl text-[var(--color-text-secondary)] leading-relaxed text-pretty">
          Co-founder of Talisman, a venture-backed B2B SaaS startup, and the PM behind its award-winning launch. Below are four case studies: product strategy, execution, zero-to-one, and how I operate. Each is grounded in real artifacts and honest outcomes.
        </p>
      </div>
      <div class="lg:order-none">
        <img
          src={heroPhoto}
          alt="Mike Gebremeskel"
          width="480"
          height="600"
          class="mx-auto w-44 sm:w-52 lg:w-full max-w-xs aspect-[4/5] rounded-2xl border border-[var(--color-border)] object-cover object-center"
        />
      </div>
    </div>
  </section>

  <section id="work" class="mx-auto max-w-7xl px-6 pb-24">
    <h2 class="eyebrow mb-6">Case studies</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {work.map((entry) => (
        <CaseStudyCard
          href={url(`work/${entry.id}`)}
          title={entry.data.title}
          summary={entry.data.summary}
          competencies={entry.data.competencies}
        />
      ))}
    </div>
  </section>

  <Recognition />

  <Testimonials />
</BaseLayout>
